{%- from 'partials/type.j2' import render_type -%}
{%- from 'partials/enum.j2' import render_enum -%}
{%- from 'partials/function.j2' import render_function -%}
{%- from 'partials/class.j2' import render_class -%}
{%- from 'partials/constant.j2' import render_constant -%}
{%- from 'partials/alias.j2' import render_alias -%}
{%- set import_state = namespace(needs_global_bindings=has_functions) -%}
{%- for item in classes -%}
{%- for method in item.methods -%}
{%- if method.static and not method.skip -%}
{%- set import_state.needs_global_bindings = true -%}
{%- endif -%}
{%- endfor -%}
{%- endfor -%}

// =============================================================================
// Auto-generated Dart wrapper for: {{ file_path }}
// {{ mapping.options.output_note | default("Generated by bindgen") }}
// =============================================================================

{%- if uses_ffi %}
import 'dart:ffi' as ffi;
{%- endif %}
{%- if uses_ui %}
import 'dart:ui' as ui;
{%- endif %}
{%- if uses_pkgffi %}
import 'package:ffi/ffi.dart' as pkgffi;
{%- endif %}
{%- if import_state.needs_global_bindings %}
import 'package:cnativeapi/cnativeapi.dart' show cnativeApiBindings;
{%- endif %}
import 'package:nativeapi/src/foundation/cnativeapi_bindings_mixin.dart';
{%- if has_handle_classes %}
import 'package:nativeapi/src/foundation/native_handle_wrapper.dart';
{%- endif %}

{%- if has_types %}
{% for item in types %}
{{ render_type(item, mapping) }}
{% endfor %}
{%- endif %}

{%- if has_enums %}
{% for item in enums %}
{{ render_enum(item, mapping) }}
{% endfor %}
{%- endif %}

{%- if has_aliases %}
{% for item in aliases %}
{{ render_alias(item, mapping) }}
{% endfor %}
{%- endif %}

{%- if has_constants %}
{% for item in constants %}
{{ render_constant(item, mapping) }}
{% endfor %}
{%- endif %}

{%- if has_functions %}
{% for item in functions %}
{{ render_function(item, mapping) }}
{% endfor %}
{%- endif %}

{%- if has_classes %}
{% for item in classes %}
{{ render_class(item, mapping) }}
{% endfor %}
{%- endif %}
